generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  clerkId    String       @unique
  email      String       @unique
  firstName  String?
  lastName   String?
  imageUrl   String?
  role       UserRole     @default(USER)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  ideaGroups IdeaGroups[]
  ideas      Idea[]

  @@index([clerkId])
  @@index([id])
  @@index([email])
  @@map("users")
}

model IdeaGroups {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ideas     Idea[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("idea_groups")
}

model Idea {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ideaGroupId String
  ideaGroup   IdeaGroups @relation(fields: [ideaGroupId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaGroupId])
  @@index([userId])
  @@map("idea")
}

enum UserRole {
  USER
  ADMIN
}
