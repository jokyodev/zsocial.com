generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  clerkId    String       @unique
  email      String       @unique
  firstName  String?
  lastName   String?
  imageUrl   String?
  role       UserRole     @default(USER)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  ideaGroups IdeaGroups[]
  ideas      Idea[]

  @@index([clerkId])
  @@index([id])
  @@index([email])
  @@map("users")
}

model IdeaGroups {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ideas     Idea[]
  position  Int

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("idea_groups")
}

model Idea {
  id      String  @id @default(uuid())
  content String?
  medias  Media[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  position    Int
  ideaGroupId String
  ideaGroup   IdeaGroups @relation(fields: [ideaGroupId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaGroupId])
  @@index([userId])
  @@map("idea")
}

model Media {
  id     String      @id @default(uuid())
  url    String
  type   String      @default("IMAGE") // IMAGE - VIDEO - GIF
  source MediaSource @default(LOCAL)

  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId String?
}

enum MediaSource {
  LOCAL
  UNSPLASH
  CANVA
  GOOGLE_DRIVE
  DROPBOX
  ONEDRIVE
}

enum UserRole {
  USER
  ADMIN
}
